{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://learning-os/schemas/parser-output.schema.json",
  "title": "Parser Output Schema",
  "description": "JSON Schema for the output of the Learning OS Markdown DSL parser.",
  "type": "object",
  "required": ["project", "stages"],
  "properties": {
    "project": {
      "type": "object",
      "required": ["title", "description", "deadline"],
      "properties": {
        "title": {
          "type": "string",
          "minLength": 1,
          "maxLength": 200
        },
        "description": {
          "type": "string",
          "minLength": 1,
          "maxLength": 2000
        },
        "reward": {
          "type": ["string", "null"],
          "maxLength": 200
        },
        "reward_price": {
          "type": ["integer", "null"],
          "minimum": 1,
          "maximum": 99999999
        },
        "deadline": {
          "type": "integer",
          "minimum": 1,
          "maximum": 1095
        }
      },
      "additionalProperties": false
    },
    "stages": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["title", "index", "tasks"],
        "properties": {
          "title": {
            "type": "string",
            "maxLength": 200
          },
          "index": {
            "type": "integer",
            "minimum": 0
          },
          "tasks": {
            "type": "array",
            "items": {
              "$ref": "#/$defs/task"
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "$defs": {
    "task": {
      "type": "object",
      "required": ["id", "title", "type", "xp"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^T\\d{3}$"
        },
        "title": {
          "type": "string",
          "minLength": 1,
          "maxLength": 200
        },
        "type": {
          "type": "string",
          "enum": ["theory", "practice", "output"]
        },
        "xp": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100
        },
        "estimate": {
          "type": ["integer", "null"],
          "minimum": 1,
          "maximum": 1440
        },
        "depends": {
          "type": ["array", "null"],
          "items": {
            "type": "string",
            "pattern": "^T\\d{3}$"
          },
          "maxItems": 100
        },
        "check": {
          "type": ["string", "null"],
          "maxLength": 500
        },
        "resource": {
          "type": ["string", "null"],
          "format": "uri",
          "pattern": "^https?://.*",
          "maxLength": 2000
        }
      },
      "additionalProperties": false
    }
  }
}
